# ============================================
# MASAL - Kisisellestirilmis Hikaye Kitabi
# API Yapilandirmasi
# ============================================

# Google Gemini API (Nano Banana Pro icin - ONERILEN)
# https://aistudio.google.com/apikey adresinden alin
GOOGLE_API_KEY=your_google_api_key_here

# fal.ai API (Alternatif - daha kolay kullanim)
# https://fal.ai/dashboard/keys adresinden alin
FAL_API_KEY=your_fal_api_key_here

# OpenAI API (Hikaye metni uretimi icin)
# https://platform.openai.com/api-keys adresinden alin
OPENAI_API_KEY=your_openai_api_key_here

# Kie.ai API (En uygun fiyat - %30-50 daha ucuz)
# https://kie.ai/api-key adresinden alin
KIE_API_KEY=your_kie_api_key_here

# Hangi gorsel API'si kullanilacak: "google", "fal" veya "kie"
IMAGE_PROVIDER=kie

# Cikti ayarlari
OUTPUT_DIR=./output
IMAGE_RESOLUTION=2K
IMAGE_FORMAT=png

# ============================================
# SHOPIFY WEBHOOK (Stage 3 — production fulfilment)
# ============================================

# Shopify webhook HMAC secret (Settings > Notifications > Webhooks)
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# Shopify admin token (product + image operations için — isteğe bağlı)
SHOPIFY_ADMIN_TOKEN=shpat_your_admin_token
SHOPIFY_HOST=masalsensin-3.myshopify.com

# ============================================
# TELEGRAM DELIVERY (Stage 3 — PDF gönderimi)
# ============================================

# Telegram Bot token (BotFather'dan alın)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Admin chat ID (kimin hesabına PDF gönderilecek)
TELEGRAM_ADMIN_CHAT_ID=1154126690
